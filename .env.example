# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/relay_crm

# JWT — use a long random string in production (openssl rand -hex 32)
JWT_SECRET=change_me_to_a_long_random_string_in_production

# Email digest (nodemailer / SMTP)
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USER=crm@yourcompany.com
SMTP_PASS=your_smtp_password
SMTP_FROM=Relay CRM <crm@yourcompany.com>

# Microsoft Graph — required for Outlook Calendar sync
# 1. Go to https://portal.azure.com → Azure Active Directory → App registrations
# 2. Register a new app, add redirect URI: http://your-server/api/calendar/callback
# 3. Add API permission: Microsoft Graph → Delegated → Calendars.ReadWrite
# 4. Create a client secret and copy it below
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
GRAPH_REDIRECT_URI=http://localhost:3001/api/calendar/callback

# Public URL of the app (used in email links and OAuth redirects)
APP_URL=http://localhost:5173
