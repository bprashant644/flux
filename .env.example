# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/flux_crm

# JWT — use a long random string in production (openssl rand -hex 32)
JWT_SECRET=change_me_to_a_long_random_string_in_production

# Email digest (nodemailer / SMTP)
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USER=crm@yourcompany.com
SMTP_PASS=your_smtp_password
SMTP_FROM=Flux <crm@yourcompany.com>

# Public URL of the app (used in email links)
APP_URL=http://localhost:5173
